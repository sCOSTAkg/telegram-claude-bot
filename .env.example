# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID пользователей Telegram, которым разрешен доступ (через запятую)
# Чтобы узнать свой ID, отправьте /start боту @userinfobot
ALLOWED_USER_IDS=your_telegram_user_id

# Рабочая директория для Claude Code (опционально)
WORKING_DIR=/Users/guest1
