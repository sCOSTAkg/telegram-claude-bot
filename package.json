{
  "name": "telegram-claude-bot",
  "version": "1.0.0",
  "description": "Telegram бот для удаленного доступа к Claude Code CLI",
  "main": "bot.js",
  "scripts": {
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop scorp-bot",
    "restart": "pm2 restart scorp-bot",
    "reload": "pm2 reload scorp-bot",
    "status": "pm2 status scorp-bot",
    "logs": "pm2 logs scorp-bot --lines 50",
    "monit": "pm2 monit",
    "dev": "node bot.js",
    "lint:module-name-collisions": "node scripts/check-module-name-collisions.js"
  },
  "keywords": [
